{
    "name"        : "simplemappr/simplemappr",
    "description" : "A point map web application for quality publications and presentations.",
    "keywords"    : ["publication", "presentation", "map", "georeference"],
    "homepage"    : "https://www.simplemappr.net",
    "license"     : "MIT",
    "authors": [
        {
          "name"  : "David P. Shorthouse",
          "email" : "davidpshorthouse@gmail.com",
          "role"  : "Developer"
        }
    ],
    "support" : {
      "email"  : "davidpshorthouse@gmail.com",
      "issues" : "https://github.com/dshorthouse/SimpleMappr/issues",
      "source" : "https://github.com/dshorthouse/SimpleMappr"
    },
    "autoload" : {
      "psr-4" : {
        "SimpleMappr\\" : "src/"
      }
    },
    "require": {
      "php"                       : ">=8.1",
      "ext-curl"                  : "*",
      "ext-gd"                    : "*",
      "ext-json"                  : "*",
      "ext-mbstring"              : "*",
      "ext-pdo"                   : "*",
      "league/csv"                : "^9.11",
      "natxet/cssmin"             : "^3.0",
      "neitanod/forceutf8"        : "^2.0",
      "phpoffice/phppresentation" : "^1.0",
      "phpoffice/phpword"         : "^1.2",
      "funiq/geophp"              : "^1.3",
      "phroute/phroute"           : "^2.2",
      "robmorgan/phinx"           : "^0.16",
      "symfony/yaml"              : "^6.4",
      "twig/twig"                 : "^3.8",
      "twig/string-extra"         : "^3.8",
      "twig/intl-extra"           : "^3.8",
      "twig/html-extra"           : "^3.8",
      "suin/php-rss-writer"       : "^1.6"
    },
    "require-dev": {
      "phpunit/phpunit"                          : "^9.6",
      "php-webdriver/webdriver"                  : "^1.15",
      "php-coveralls/php-coveralls"              : "^2.7",
      "squizlabs/php_codesniffer"                : "^3.9",
      "php-parallel-lint/php-parallel-lint"      : "^1.4",
      "php-parallel-lint/php-console-highlighter": "^1.0"
    },
    "config": {
      "sort-packages": true
    }
}
